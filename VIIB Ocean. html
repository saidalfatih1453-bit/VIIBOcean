<!-- KARTU INFORMASI -->
<section>
<h2 class="section-title">📋 Kartu Informasi</h2>

<div class="info-grid">

<div class="card">
<h3>👨‍🏫 Wali Kelas</h3>
<p>Pak Dheden</p>
</div>

<div class="card">
<h3>👨‍🎓 Jumlah Siswa</h3>
<p>35 Siswa</p>
</div>

<div class="card">
<h3>🌊 Tema</h3>
<p>Ocean Memories</p>
</div>

<div class="card">
<h3>📚 Kelas</h3>
<p>VIIB</p>
</div>

<div class="card">
<h3>💙 Semangat</h3>
<p>Kompak, Kreatif, dan Berprestasi</p>
</div>

</div>
</section>

<footer>
<p>🌊 VIIB Ocean Memories © 2026 | Bersama Mengarungi Samudra Ilmu</p>
</footer>

</body>
</html>